%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5568db52b4fea43afb3455241bff86dd, type: 3}
  m_Name: 03_Stage3_CutScene
  m_EditorClassIdentifier: Assembly-CSharp::CutsceneData
  targetBGM: 3
  frames:
  - Texts:
    - dialogueText: "\uB300\uD559\uAD50 \uB4E4\uC5B4\uAC00\uC11C\uB3C4, \uB9CE\uC774
        \uD798\uB4E4\uC5C8\uC8E0."
      textPos: {x: 0, y: 0}
      textAlignment: 0
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
    moveImages: []
  - Texts:
    - dialogueText: "\uB9DE\uC544.\n\uB098 \uC815\uB9D0 \uC5F4\uC2EC\uD788 \uB178\uB825\uD588\uB294\uB370,\n\uC544\uBB34\uAC83\uB3C4
        \uC774\uB8E8\uC9C0 \uBABB\uD588\uC5B4."
      textPos: {x: 0, y: 0}
      textAlignment: 0
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
    moveImages: []
  - Texts:
    - dialogueText: "\uACF5\uBAA8\uC804, \uB300\uC678\uD65C\uB3D9, \uD504\uB85C\uC81D\uD2B8\u2026\n\uC900\uBE44\uD55C
        \uAC83\uB9C8\uB2E4 \uBAA8\uB450 \uBB34\uC0B0\uB418\uACE0\n\uB098\uB294 \uAC00\uCE58
        \uC5C6\uB294 \uC0AC\uB78C\uC774 \uB418\uC5C8\uC5B4."
      textPos: {x: 0, y: 0}
      textAlignment: 0
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
    moveImages: []
  - Texts:
    - dialogueText: "\uB0B4\uAC00 \uC798 \uCC59\uACA8\uBA39\uC5C8\uC5B4\uC57C \uD558\uB294\uB370."
      textPos: {x: 0, y: 0}
      textAlignment: 0
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
    moveImages: []
  - Texts:
    - dialogueText: "\uB300\uD559\uC5D0 \uAC00\uB3C4 \uB098\uB294 \uC5EC\uC804\uD788
        \uACE0\uD1B5 \uC18D\uC5D0\uC11C \uC0B4\uACE0 \uC788\uC5C8\uC5B4."
      textPos: {x: 0, y: 0}
      textAlignment: 0
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
    moveImages: []
  - Texts:
    - dialogueText: "\uBC88\uB4EF\uD558\uAC8C \uC798 \uC0B4\uACE0 \uC2F6\uC5C8\uB294\uB370."
      textPos: {x: 0, y: 0}
      textAlignment: 0
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
    moveImages: []
  - Texts:
    - dialogueText: "\uADF8\uB798\uB3C4, \uB3D9\uC544\uB9AC\uC5D0\uC11C \uAE30\uD0C0\uB97C
        \uCE60 \uB550 \uC88B\uC558\uB358 \uAC70 \uAC19\uC544.\n\uB098\uB984, \uADF8\uB7AC\uB358
        \uAC70 \uAC19\uC544."
      textPos: {x: 0, y: 0}
      textAlignment: 0
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
    moveImages: []
  - Texts:
    - dialogueText: "\uB2E4\uC74C \uC774\uC57C\uAE30\uB3C4, \uCC3E\uC544\uC640\uC904
        \uC218 \uC788\uC5B4?"
      textPos: {x: 0, y: 0}
      textAlignment: 0
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
    moveImages: []
  - Texts:
    - dialogueText: "\uB124, \uB2F9\uC5F0\uD558\uC8E0!\n\uC138\uC0C1\uC5D0\uC11C
        \uC81C\uC77C \uBE60\uB974\uAC8C \uCC3E\uC544\uC62C\uAC8C\uC694!"
      textPos: {x: 0, y: 0}
      textAlignment: 0
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
    moveImages:
    - sprite: {fileID: 21300000, guid: a9f5c7e527cb44b17a81acdd0f2871b3, type: 3}
      size: {x: 2340, y: 1080}
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
      startPos: {x: 0, y: 50}
      endPos: {x: 1200, y: 100}
      duration: 1.5
      ease: 26
