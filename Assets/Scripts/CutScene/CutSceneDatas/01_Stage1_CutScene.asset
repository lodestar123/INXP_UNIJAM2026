  targetBGM: 3
  frames:
  - Texts:
    - dialogueText: "\uADF8\uB7F0\uB370,\n\uC774\uAC8C, \uB0B4\uAC00 \uD589\uBCF5\uD588\uB358
        \uCD94\uC5B5\uC774\uB77C\uACE0?"
      textPos: {x: 0, y: 100}
      textAlignment: 513
      fadeSettings:
        useFade: 1
        startDelay: 0
        fadeInDuration: 0.5
        fadeOutDuration: 0
    - dialogueText: "\uD558\uC9C0\uB9CC \uB354 \uBD88\uD589\uD55C \uC77C\uC774 \uB9CE\uC558\uC5B4."
      textPos: {x: 0, y: 100}
      textAlignment: 516
      fadeSettings:
        useFade: 1
        startDelay: 0.8
        fadeInDuration: 0.5
        fadeOutDuration: 0
    moveImages:
    - sprite: {fileID: 21300000, guid: 530de91ff88eb485ca703db03d5e1b2c, type: 3}
      size: {x: 2340, y: 1080}
      fadeSettings:
        useFade: 0
        startDelay: 0
