  m_Script: {fileID: 11500000, guid: 5568db52b4fea43afb3455241bff86dd, type: 3}
  m_Name: 01_Stage1_CutScene
  m_EditorClassIdentifier: Assembly-CSharp::CutsceneData
  frames:
  - bgSprite: {fileID: 0}
    dialogueText: "\uADF8\uB7F0\uB370,\n\uC774\uAC8C, \uB0B4\uAC00 \uD589\uBCF5\uD588\uB358
      \uCD94\uC5B5\uC774\uB77C\uACE0?"
    textPos: {x: -150, y: 0}
    moveImages: []
  - bgSprite: {fileID: 0}
    dialogueText: "\uD559\uAD50\uC758 \uBAA8\uB4E0 \uC560\uB4E4\uC774 \uB0A0 \uC2EB\uC5B4\uD588\uB2E8
      \uB9D0\uC774\uC57C.\n\uC560\uB4E4\uC774 \uB04A\uC784\uC5C6\uC774 \uB0A0 \uC695\uD558\uACE0
      \uAD34\uB86D\uD788\uACE0....\n\uC544\uC9C1\uB3C4 \uADF8\uAC8C \uAFC8\uC5D0
      \uB098\uC640."
    textPos: {x: -150, y: 200}
    moveImages: []
  - bgSprite: {fileID: 0}
    dialogueText: "\uACA8\uC6B0 \uC774\uB534 \uAC83\uB4E4\uC774\n\uB0B4 \uC778\uC0DD\uC774
      \uBD88\uD589\uD558\uC9C0 \uC54A\uC558\uB2E4\uB294 \uC99D\uAC70\uAC00 \uB420
      \uC218 \uC5C6\uC5B4."
    textPos: {x: 600, y: -380}
    moveImages: []
  - bgSprite: {fileID: 0}
    dialogueText: "...\uB2E4\uB978, \uB2E4\uB978 \uAC8C \uC788\uC744 \uAC70\uC5D0\uC694!"
    textPos: {x: -150, y: -300}
    moveImages: []
  - bgSprite: {fileID: 0}
    dialogueText: "\uAF2D \uB0A9\uB4DD\uD558\uC2E4 \uB9CC\uD55C \uCD94\uC5B5\uC744
      \uCC3E\uC544\uB4DC\uB9B4\uAC8C\uC694!"
    textPos: {x: -150, y: -300}
    moveImages: []
