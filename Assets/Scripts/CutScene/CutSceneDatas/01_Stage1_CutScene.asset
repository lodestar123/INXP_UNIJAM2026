        fadeOutDuration: 0
      startPos: {x: 0, y: 0}
      endPos: {x: 0, y: 0}
      duration: 0
      ease: 0
  - Texts:
    - dialogueText: "\uD559\uAD50\uC758 \uBAA8\uB4E0 \uC560\uB4E4\uC774 \uB0A0 \uC2EB\uC5B4\uD588\uB2E8
        \uB9D0\uC774\uC57C.\n\uC560\uB4E4\uC774 \uB04A\uC784\uC5C6\uC774 \uB0A0 \uC695\uD558\uACE0
        \uAD34\uB86D\uD788\uACE0\u2026\n\uC544\uC9C1\uB3C4 \uADF8\uAC8C \uAFC8\uC5D0
        \uB098\uC640."
      textPos: {x: 0, y: 300}
      textAlignment: 513
      fadeSettings:
        useFade: 1
        startDelay: 0
        fadeInDuration: 0.5
        fadeOutDuration: 0
    moveImages:
    - sprite: {fileID: 21300000, guid: 2374b147857d547f4b17912de3c5e1a5, type: 3}
      size: {x: 2340, y: 1080}
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
      startPos: {x: 0, y: 0}
      endPos: {x: 0, y: 0}
      duration: 0
      ease: 0
  - Texts:
    - dialogueText: "\uACA8\uC6B0 \uC774\uB534 \uAC83\uB4E4\uC774\n\uB0B4 \uC778\uC0DD\uC774
        \uBD88\uD589\uD558\uC9C0 \uC54A\uC558\uB2E4\uB294 \uC99D\uAC70\uAC00 \uB420
        \uC218 \uC5C6\uC5B4."
      textPos: {x: 0, y: 100}
      textAlignment: 516
      fadeSettings:
        useFade: 1
        startDelay: 0
        fadeInDuration: 0.5
        fadeOutDuration: 0
    moveImages:
    - sprite: {fileID: 21300000, guid: 4117f28da64aa440788ecd4726cd21b3, type: 3}
      size: {x: 2340, y: 1080}
      fadeSettings:
        useFade: 0
