  frames:
  - bgSprite: {fileID: 0}
    dialogueText: "\uB0B4\uAC00 \uD55C \uB2EC \uC548\uC5D0 \uC8FD\uC744 \uAC70\uB77C\uACE0...."
    textPos: {x: -150, y: 100}
    moveImages: []
  - bgSprite: {fileID: 0}
    dialogueText: "\uADF8\uB807\uAD6C\uB098.\n\uB0B4 \uC0B6\uC740 \uACE0\uD1B5\uC758
      \uC5F0\uC18D\uC774\uC5C8\uC5B4....\n\uC5B4\uB9B4 \uC801\uBD80\uD130, \uD589\uBCF5\uD55C
      \uC21C\uAC04\uC740 \uB2E8 \uD558\uB098\uB3C4 \uC5C6\uC5C8\uAC70\uB4E0."
