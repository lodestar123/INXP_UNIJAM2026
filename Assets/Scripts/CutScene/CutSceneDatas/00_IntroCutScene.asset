    moveImages:
    - sprite: {fileID: 0}
      startPos: {x: 0, y: 0}
      endPos: {x: 0, y: 0}
      duration: 0
      ease: 0
  - bgSprite: {fileID: 0}
    dialogueText: "\uC774\uB807\uAC8C \uC8FD\uAC8C \uB418\uC5B4\uC11C \uC5BC\uB9C8\uB098
      \uB2E4\uD589\uC778\uC9C0 \uBAB0\uB77C."
    textPos: {x: -150, y: 100}
    moveImages: []
  - bgSprite: {fileID: 0}
    dialogueText: "\uC544\uB2C8\uC5D0\uC694!!\n\uBD84\uBA85 \uC88B\uC740 \uCD94\uC5B5\uC774
      \uC788\uC5C8\uB2F5\uB2C8\uB2E4!!"
    textPos: {x: 780, y: 100}
    moveImages: []
  - bgSprite: {fileID: 0}
    dialogueText: "\uC78A\uACE0 \uC788\uB358 \uCD94\uC5B5\uC744 \uC81C\uAC00, \uCC3E\uC544\uB4DC\uB9B4\uAC8C\uC694!!"
