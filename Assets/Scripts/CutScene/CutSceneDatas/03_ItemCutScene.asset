  targetBGM: 0
  frames:
  - Texts: []
    moveImages:
    - sprite: {fileID: 2761035800938196748, guid: 8d0e7ddf39b4f494a86f4dff7ce54425, type: 3}
      size: {x: 300, y: 300}
      fadeSettings:
        useFade: 0
