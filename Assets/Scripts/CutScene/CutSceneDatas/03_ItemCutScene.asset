        fadeOutDuration: 0
      startPos: {x: 0, y: 100}
      endPos: {x: 0, y: 0}
      duration: 2
      ease: 15
  - Texts:
    - dialogueText: "\uB9CE\uC740 \uAC78 \uCC0D\uC5C8\uC5C8\uB294\uB370, \uCE5C\uAD6C\uB4E4\uC744
        \uCC0D\uC5B4\uC904 \uB54C\uAC00 \uADF8\uB807\uAC8C \uC88B\uC558\uB358 \uAC70
        \uAC19\uC544.\n\uC560\uB4E4\uC774 \uC6C3\uB294 \uC5BC\uAD74\uC774 \uBCF4\uAE30
        \uC88B\uC558\uC5B4."
      textPos: {x: 0, y: -300}
      textAlignment: 514
      fadeSettings:
        useFade: 1
        startDelay: 0
        fadeInDuration: 0.5
        fadeOutDuration: 0
    moveImages:
    - sprite: {fileID: -483785915386784597, guid: 02abc685878685d4287df214cc7b86c4, type: 3}
      size: {x: 300, y: 300}
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
      startPos: {x: 0, y: 0}
      endPos: {x: 0, y: 0}
      duration: 0
      ease: 0
  - Texts:
    - dialogueText: "\uB099\uC11C\uD560 \uB54C \uAF2D \uD544\uC694\uD588\uB358 \uBCFC\uD39C\uC774\uC5C8\uC5B4.\n\uAD50\uACFC\uC11C
        \uD55C\uCF20\uC5D0 \uC791\uC740 \uCE90\uB9AD\uD130 \uD558\uB098\uB97C \uADF8\uB9AC\uBA74\uC11C
        \uB2EC\uCE75 \uB2EC\uCE75 \uC18C\uB9AC\uB97C \uB0C8\uC5C8\uC9C0."
      textPos: {x: 0, y: -300}
      textAlignment: 514
      fadeSettings:
        useFade: 1
        startDelay: 0
        fadeInDuration: 0.5
        fadeOutDuration: 0
    moveImages:
    - sprite: {fileID: -3048819314940337248, guid: 02abc685878685d4287df214cc7b86c4, type: 3}
      size: {x: 300, y: 300}
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
      startPos: {x: 0, y: 0}
      endPos: {x: 0, y: 0}
      duration: 0
      ease: 0
  - Texts:
    - dialogueText: "\uB0B4\uAC00 \uAC00\uC7A5 \uC88B\uC544\uD558\uB358 \uC138\uC0C1\uC774
        \uC774 \uC791\uC740 \uAC8C\uC784\uAE30 \uC548\uC5D0 \uC788\uC5C8\uC5B4.\n\uBAA8\uB4E0
        \uAC78 \uC78A\uACE0 \uBE60\uC838\uB4E4 \uC218 \uC788\uB294 \uC138\uC0C1."
      textPos: {x: 0, y: -300}
      textAlignment: 514
      fadeSettings:
        useFade: 1
        startDelay: 0
        fadeInDuration: 0.5
        fadeOutDuration: 0
    moveImages:
    - sprite: {fileID: -6053909342743001456, guid: 02abc685878685d4287df214cc7b86c4, type: 3}
      size: {x: 300, y: 300}
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
      startPos: {x: 0, y: 0}
      endPos: {x: 0, y: 0}
      duration: 0
      ease: 0
  - Texts:
    - dialogueText: "\uBE75\uBCF4\uB2E4\uB294 \uB760\uBD80\uC530\uC774 \uB354 \uC911\uC694\uD588\uB358
        \uAC70 \uAC19\uC544.\n\uC568\uBC94\uC5D0 \uB760\uBD80\uC530\uC744 \uC5C4\uCCAD\uB098\uAC8C
        \uBAA8\uC73C\uAE30\uB3C4 \uD588\uC5C8\uC5B4.\n\uADF8\uB798\uB3C4 \uBE75\uB3C4
        \uB9DB\uC788\uAC8C \uBA39\uC5C8\uC5C8\uC9C0."
      textPos: {x: 0, y: -300}
      textAlignment: 514
      fadeSettings:
        useFade: 1
        startDelay: 0
        fadeInDuration: 0.5
        fadeOutDuration: 0
    moveImages:
    - sprite: {fileID: 3633937587237763438, guid: 02abc685878685d4287df214cc7b86c4, type: 3}
      size: {x: 300, y: 300}
      fadeSettings:
        useFade: 0
        startDelay: 0
        fadeInDuration: 0
        fadeOutDuration: 0
      startPos: {x: 0, y: 0}
      endPos: {x: 0, y: 0}
      duration: 0
      ease: 0
  - Texts:
    - dialogueText: "\uCE60\uD310 \uB2F9\uBC88\uC77C \uB54C, \uAE00\uC528\uB97C \uD558\uB098\uD558\uB098
        \uAF3C\uAF3C\uD788 \uC9C0\uC6CC\uB0B4\uB824\uAC00\uB294 \uB9DB\uC774 \uC788\uC5C8\uC5B4.\n\uC774\uC81C
        \uB2E4\uC2DC\uB294 \uADF8 \uCE60\uD310\uC744 \uBABB \uBCF4\uACA0\uC9C0."
      textPos: {x: 0, y: -300}
      textAlignment: 514
      fadeSettings:
        useFade: 1
        startDelay: 0
        fadeInDuration: 0.5
        fadeOutDuration: 0
